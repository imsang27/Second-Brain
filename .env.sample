# Hugging Face Access Token (Read)
HF_TOKEN=hf_...

# Hardware & Model Settings
DEVICE=cuda
EMBEDDING_MODEL=BAAI/bge-m3
OLLAMA_MODEL=qwen3.5:9b

# Storage Settings
DB_PATH=./chroma_db
RETRIEVAL_K=3

# System Settings
TOKENIZERS_PARALLELISM=false

# Disable Hugging Face Hub progress bars (e.g., "Loading weights")
HF_HUB_DISABLE_PROGRESS_BARS=1