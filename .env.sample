# --- Required Settings ---
# Hugging Face Access Token for downloading embedding models
HF_TOKEN=hf_...

# Absolute path to your local markdown notes directory
# Example: C:/Users/YourName/Documents/Notes
NOTES_PATH=C:/path/to/your/notes

# --- Hardware & Model Settings ---
# Device to run the models (cuda for NVIDIA GPU, cpu for others)
DEVICE=cuda
# Embedding model for converting text to vectors
EMBEDDING_MODEL=BAAI/bge-m3
# Local LLM model name via Ollama
OLLAMA_MODEL=qwen3.5:9b

# --- Storage & Retrieval Settings ---
# Directory where the vector database will be stored
DB_PATH=./chroma_db
# Number of relevant documents to retrieve for each query
RETRIEVAL_K=3

# --- System Optimizations ---
# Avoid parallelism issues with certain tokenizers
TOKENIZERS_PARALLELISM=false
# Hide progress bars for cleaner terminal output
HF_HUB_DISABLE_PROGRESS_BARS=1